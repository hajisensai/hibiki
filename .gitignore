**/android/build/

# AI/planning docs
AGENTS.md
SPEC.md

# ADB test artifacts
test_screenshots/
screenshot_*.png
tmp_screen*.png
# uiautomator dump XML (lands in .codex-test/ and repo root) — keep ignored.
*.xml
# ...but vendored third_party packages are build inputs and must be tracked in
# full (e.g. flutter_inappwebview_android needs android/src/main/res/*.xml so
# R.layout.*/R.id.* resolve on a fresh checkout). Re-include their XML.
!third_party/**/*.xml

# QA screenshots and debug artifacts
qa-*.png
qa-*-summary.txt
popup_*.png
debug_screenshot.png
# Root-level UI appearance/comparison debug screenshots (root-anchored so it
# never shadows a real asset named hibiki_*.png in a subdir)
/hibiki_*.png

# Claude agent worktrees
.claude/worktrees/

# Codex agent worktrees
.worktrees/

# Codex test artifacts (fixtures, screenshots, evidence)
.codex-test/

# Codex test outputs (flutter run logs, temp files)
flutter_run_*.txt
*_tmp_before.txt

